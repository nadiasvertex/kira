module main

# `rev` reverses a double-ended iterator.
#
# Demonstrates: reversing a forward list.

def main() -> int32:
    let nums = [1, 2, 3]

    # Reversed: 3, 2, 1
    var r = nums.into_iter().rev()
    println("reversed={r.next().unwrap()}")
    println("reversed={r.next().unwrap()}")
    println("reversed={r.next().unwrap()}")
    return 0
