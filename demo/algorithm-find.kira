module main

# `find` returns the first element that satisfies the predicate.
#
# Demonstrates: finding a positive element, a negative element,
# and not finding anything.

def main() -> int32:
    let nums = [1, 3, -5, 4, -2]

    # First positive is 1
    println("find_first_positive={nums.into_iter().find(x => x > 0).unwrap()}")

    # First negative is -5
    println("find_first_negative={nums.into_iter().find(x => x < 0).unwrap()}")

    # Not finding
    println("find_none={nums.into_iter().find(x => x > 100).is_none()}")
    return 0
