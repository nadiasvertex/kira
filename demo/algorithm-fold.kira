module main

# `fold` accumulates values using an initial state and a combining function.
#
# Demonstrates: a basic fold, fold on an empty iterator,
# and accumulating a list via fold.

def main() -> int32:
    let nums = [1, 2, 3, 4, 5]
    let nv = nums.iter().values()

    # Sum: start at 0, add each element
    println("sum={nv.fold(0, (acc, x) => acc + x)}")
    # Product: start at 1, multiply each element
    println("product={nv.fold(1, (acc, x) => acc * x)}")
    # String concatenation
    let words = ["hello", " ", "world"]
    let result = words.iter().values().fold("", (acc, x) => acc + x)
    println("concat={result}")

    # Empty iterator returns the initial value
    let empty: list[int32] = []
    println("empty_fold={empty.iter().values().fold(42, (acc, x) => acc + x)}")
    return 0
