module stress.expr_generic_calls_and_splice

static def derive_show[T]() -> def_expr:
  let target = describe[T]()
  `impl show for point:`

def run(raw_index):
  let sender = channel[str](capacity: 32)
  let watcher = watch[config](initial: default_config())
  let value = index[n].try_from(raw_index)
  sender.send(value)

~derive_show[point]()
