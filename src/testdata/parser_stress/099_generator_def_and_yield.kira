module stress.generator_def_and_yield

generator def fibonacci() -> some iterator[uint64]:
  var a: uint64 = 0
  var b: uint64 = 1
  while true:
    yield a
    (a, b) = (b, a + b)

generator def evens(limit: int32) -> some iterator[int32]:
  var n = 0
  while n < limit:
    if n % 2 == 0:
      yield n
    match n:
      0 => yield 0
      _ => yield n
    n = n + 1
