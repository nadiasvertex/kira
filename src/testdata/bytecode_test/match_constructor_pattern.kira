module sample
type shape = @circle(float64) | @square(float64) | @empty
def area(s: shape) -> float64:
    return match s:
        @circle(r) => r * r
        @square(side) => side * side
        @empty => 0.0
def circle_area(r: float64) -> float64:
    return area(@circle(r))
def empty_area() -> float64:
    return area(@empty)
