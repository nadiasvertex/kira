module main

def main() -> int32:
    let name = "Alice"
    let age = 30
    let pi = 3.1415926535

    println("Name: {name :>10}")
    println("Age:  {age :03}")
    println("Pi:   {pi :.2f}")
    println("Hex:  {255 :04x}")
    println("Bin:  {255 :08b}")

    let width: usize = 8
    println("{width=}")

    let neg: int32 = -42
    println("{neg :06}")

    println("{{escaped}} stays literal")
    return 0
