module main

# The `std.algo` terminals (design §6.1).
#
# Each check pairs a true case with a false one, or uses positionally distinct
# weights, so a terminal that returned the right *kind* of answer for the
# wrong reason is still caught. Sources are `iter().values()` rather than
# bare `iter()`: `iter()` yields `&T`, and a terminal returning `T` then
# returns a reference, which the bytecode VM cannot represent as a value yet,
# so `values()` dereferences back to `T`. `iter()` borrows rather than moving
# its list, which is what lets each source variable feed more than one
# terminal here — `into_iter()` moves, and every one of these sources is
# drained by several terminals in turn.
#
# `group_by` is absent: it needs a map type, which Phase 7 brings.

def main() -> int32:
    let xs = [3, 1, 4, 1, 5]

    println("count={xs.iter().values().count()}")

    # Positional weights: a fold that visited the right elements in the wrong
    # order cannot reach the same total.
    println("fold={xs.iter().values().fold(0, (a, x) => a * 10 + x)}")
    println("reduce={xs.iter().values().reduce((a, x) => a * 10 + x).unwrap()}")

    # The empty cases, where `fold` still answers and `reduce` cannot.
    let empty: list[int32] = []
    println("fold_empty={empty.iter().values().fold(7, (a, x) => a + x)}")
    println("reduce_empty={empty.iter().values().reduce((a, x) => a + x).is_none()}")

    # `for_each` is run for its effects, so the effect is what is checked.
    # A lambda body is an expression, so the effect cannot be an assignment.
    # Printing is the effect here, which also makes the order and the count
    # observable rather than just the fact that something ran. (Accumulating
    # into a captured local instead does not lower today -- `spec/todo.md`.)
    xs.iter().values().for_each((x) => println("for_each={x * 2}"))

    # True and false for each predicate terminal, over the same source.
    println("any_yes={xs.iter().values().any((x) => x > 4)}")
    println("any_no={xs.iter().values().any((x) => x > 9)}")
    println("all_yes={xs.iter().values().all((x) => x > 0)}")
    println("all_no={xs.iter().values().all((x) => x > 1)}")

    # `all` over an empty source is true and `any` is false -- the readings
    # that make them compose, and the ones most easily got backwards.
    println("any_empty={empty.iter().values().any((x) => true)}")
    println("all_empty={empty.iter().values().all((x) => false)}")

    # `find` returns the *first* match: 4 and 5 both pass, so a terminal
    # returning the last would answer 5.
    println("find={xs.iter().values().find((x) => x > 3).unwrap()}")
    println("find_miss={xs.iter().values().find((x) => x > 9).is_none()}")

    # Likewise `find_map`, whose first `@some` is at the 4.
    println("find_map={xs.iter().values().find_map((x) => if x > 3: @some(x * 100) else: @none).unwrap()}")

    # 4 sits at index 2, which is neither its value nor the length -- an
    # off-by-one or a returned element rather than an index would show.
    println("position={xs.iter().values().position((x) => x > 3).unwrap()}")
    println("position_miss={xs.iter().values().position((x) => x > 9).is_none()}")

    # `last` is 5 and `max` is also 5, so `last` is checked on a source whose
    # final element is *not* the largest.
    let ys = [2, 9, 6]
    println("last={ys.iter().values().last().unwrap()}")
    println("last_empty={empty.iter().values().last().is_none()}")

    println("nth0={xs.iter().values().nth(0).unwrap()}")
    println("nth2={xs.iter().values().nth(2).unwrap()}")
    println("nth_past={xs.iter().values().nth(5).is_none()}")

    println("min={xs.iter().values().min().unwrap()}")
    println("max={xs.iter().values().max().unwrap()}")
    println("min_empty={empty.iter().values().min().is_none()}")

    # A key that reverses the order, so `min_by_key` must disagree with `min`
    # and agree with `max`. Sharing a source with them makes that visible.
    println("min_by_key={xs.iter().values().min_by_key((x) => 0 - x).unwrap()}")
    println("max_by_key={xs.iter().values().max_by_key((x) => 0 - x).unwrap()}")

    # Both halves, and their order within each half. 3 and 4 and 5 pass; the
    # two 1s do not, and stay in the order they were yielded.
    let parts = xs.iter().values().partition((x) => x > 2)
    println("part_yes={parts.0.len()} part_no={parts.1.len()}")
    println("part_first={parts.0[0]} part_last={parts.0[2]}")

    # Equal length and equal elements, then each failure mode separately: a
    # differing element, a shorter left, and a shorter right.
    let a = [1, 2, 3]
    let b = [1, 2, 3]
    let c = [1, 2, 4]
    let d = [1, 2]
    println("eq_same={a.iter().values().eq_by(b.iter().values(), (p, q) => p == q)}")
    println("eq_diff={a.iter().values().eq_by(c.iter().values(), (p, q) => p == q)}")
    println("eq_short_right={a.iter().values().eq_by(d.iter().values(), (p, q) => p == q)}")
    println("eq_short_left={d.iter().values().eq_by(a.iter().values(), (p, q) => p == q)}")

    comparators()
    identities()
    return 0

# The comparator-taking terminals, which need a real `ordering`.
def cmp_int(a: int32, b: int32) -> ordering:
    if a < b:
        return @less
    if a > b:
        return @greater
    return @equal

# Reversed, so `min_by` under it must agree with `max` and disagree with `min`
# over the same source -- the same trick the `_by_key` checks use.
def rcmp_int(a: int32, b: int32) -> ordering:
    return cmp_int(b, a)

# The comparators are passed as lambdas rather than by name: a bare function
# value outside call position does not lower yet (`spec/todo.md`).
def show_ord(o: ordering) -> int32:
    return match o:
        @less => 1
        @equal => 2
        @greater => 3

def comparators() -> unit:
    let xs = [3, 1, 4, 1, 5]
    let empty: list[int32] = []

    println("min_by={xs.iter().values().min_by((a, b) => cmp_int(a, b)).unwrap()}")
    println("max_by={xs.iter().values().max_by((a, b) => cmp_int(a, b)).unwrap()}")
    println("min_by_rev={xs.iter().values().min_by((a, b) => rcmp_int(a, b)).unwrap()}")
    println("max_by_rev={xs.iter().values().max_by((a, b) => rcmp_int(a, b)).unwrap()}")
    println("min_by_empty={empty.iter().values().min_by((a, b) => cmp_int(a, b)).is_none()}")

    # Lexicographic: equal, then a difference decided at the second element
    # rather than the first, then each length case. The differing pair is not
    # in first position so a `cmp_by` that only ever looked at one pair would
    # answer `@equal` for it.
    let a = [1, 2, 3]
    let b = [1, 2, 3]
    let c = [1, 9, 0]
    let d = [1, 2]
    println("cmp_same={show_ord(a.iter().values().cmp_by(b.iter().values(), (a, b) => cmp_int(a, b)))}")
    println("cmp_lt={show_ord(a.iter().values().cmp_by(c.iter().values(), (a, b) => cmp_int(a, b)))}")
    println("cmp_gt={show_ord(c.iter().values().cmp_by(a.iter().values(), (a, b) => cmp_int(a, b)))}")

    # A prefix is less than the whole, and the decision comes from running out
    # rather than from any comparison.
    println("cmp_prefix={show_ord(d.iter().values().cmp_by(a.iter().values(), (a, b) => cmp_int(a, b)))}")
    println("cmp_longer={show_ord(a.iter().values().cmp_by(d.iter().values(), (a, b) => cmp_int(a, b)))}")

# `sum` and `product` go through the `zero`/`one` traits in `std.traits`,
# whose only implementors are the numeric primitives.
def identities() -> unit:
    let xs = [1, 2, 3, 4]
    let empty: list[int32] = []

    println("sum={xs.iter().values().sum()}")
    println("product={xs.iter().values().product()}")

    # The identities themselves, which are the whole reason these return `T`
    # rather than `option[T]`. A `sum` that started from an uninitialized
    # accumulator, or a `product` that started from zero, shows up here and
    # nowhere else -- every non-empty case above would still be right.
    println("sum_empty={empty.iter().values().sum()}")
    println("product_empty={empty.iter().values().product()}")

    # A second element type, so the impls really are per-type rather than one
    # instantiation reused. `float64` also catches a `one()` written as an
    # integer literal.
    let fs = [1.5, 2.5]
    println("sum_float={fs.iter().values().sum()}")
    println("product_float={fs.iter().values().product()}")
