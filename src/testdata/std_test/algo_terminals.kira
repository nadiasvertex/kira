module main

# The `std.algo` terminals (design §6.1).
#
# Each check pairs a true case with a false one, or uses positionally distinct
# weights, so a terminal that returned the right *kind* of answer for the
# wrong reason is still caught. Sources are `into_iter()` rather than `iter()`
# throughout: `iter()` yields `&T`, and a terminal returning `T` then returns
# a reference, which the bytecode VM cannot represent as a value yet.
#
# `sum`/`product` are absent: they need an additive identity the language
# cannot name yet, which is recorded in `spec/todo.md`.

def main() -> int32:
    let xs = [3, 1, 4, 1, 5]

    println("count={xs.into_iter().count()}")

    # Positional weights: a fold that visited the right elements in the wrong
    # order cannot reach the same total.
    println("fold={xs.into_iter().fold(0, (a, x) => a * 10 + x)}")
    println("reduce={xs.into_iter().reduce((a, x) => a * 10 + x).unwrap()}")

    # The empty cases, where `fold` still answers and `reduce` cannot.
    let empty: list[int32] = []
    println("fold_empty={empty.into_iter().fold(7, (a, x) => a + x)}")
    println("reduce_empty={empty.into_iter().reduce((a, x) => a + x).is_none()}")

    # `for_each` is run for its effects, so the effect is what is checked.
    # A lambda body is an expression, so the effect cannot be an assignment.
    # Printing is the effect here, which also makes the order and the count
    # observable rather than just the fact that something ran. (Accumulating
    # into a captured local instead does not lower today -- `spec/todo.md`.)
    xs.into_iter().for_each((x) => println("for_each={x * 2}"))

    # True and false for each predicate terminal, over the same source.
    println("any_yes={xs.into_iter().any((x) => x > 4)}")
    println("any_no={xs.into_iter().any((x) => x > 9)}")
    println("all_yes={xs.into_iter().all((x) => x > 0)}")
    println("all_no={xs.into_iter().all((x) => x > 1)}")

    # `all` over an empty source is true and `any` is false -- the readings
    # that make them compose, and the ones most easily got backwards.
    println("any_empty={empty.into_iter().any((x) => true)}")
    println("all_empty={empty.into_iter().all((x) => false)}")

    # `find` returns the *first* match: 4 and 5 both pass, so a terminal
    # returning the last would answer 5.
    println("find={xs.into_iter().find((x) => x > 3).unwrap()}")
    println("find_miss={xs.into_iter().find((x) => x > 9).is_none()}")

    # Likewise `find_map`, whose first `@some` is at the 4.
    println("find_map={xs.into_iter().find_map((x) => if x > 3: @some(x * 100) else: @none).unwrap()}")

    # 4 sits at index 2, which is neither its value nor the length -- an
    # off-by-one or a returned element rather than an index would show.
    println("position={xs.into_iter().position((x) => x > 3).unwrap()}")
    println("position_miss={xs.into_iter().position((x) => x > 9).is_none()}")

    # `last` is 5 and `max` is also 5, so `last` is checked on a source whose
    # final element is *not* the largest.
    let ys = [2, 9, 6]
    println("last={ys.into_iter().last().unwrap()}")
    println("last_empty={empty.into_iter().last().is_none()}")

    println("nth0={xs.into_iter().nth(0).unwrap()}")
    println("nth2={xs.into_iter().nth(2).unwrap()}")
    println("nth_past={xs.into_iter().nth(5).is_none()}")

    println("min={xs.into_iter().min().unwrap()}")
    println("max={xs.into_iter().max().unwrap()}")
    println("min_empty={empty.into_iter().min().is_none()}")

    # A key that reverses the order, so `min_by_key` must disagree with `min`
    # and agree with `max`. Sharing a source with them makes that visible.
    println("min_by_key={xs.into_iter().min_by_key((x) => 0 - x).unwrap()}")
    println("max_by_key={xs.into_iter().max_by_key((x) => 0 - x).unwrap()}")

    # Both halves, and their order within each half. 3 and 4 and 5 pass; the
    # two 1s do not, and stay in the order they were yielded.
    let parts = xs.into_iter().partition((x) => x > 2)
    println("part_yes={parts.0.len()} part_no={parts.1.len()}")
    println("part_first={parts.0[0]} part_last={parts.0[2]}")

    # Equal length and equal elements, then each failure mode separately: a
    # differing element, a shorter left, and a shorter right.
    let a = [1, 2, 3]
    let b = [1, 2, 3]
    let c = [1, 2, 4]
    let d = [1, 2]
    println("eq_same={a.into_iter().eq_by(b.into_iter(), (p, q) => p == q)}")
    println("eq_diff={a.into_iter().eq_by(c.into_iter(), (p, q) => p == q)}")
    println("eq_short_right={a.into_iter().eq_by(d.into_iter(), (p, q) => p == q)}")
    println("eq_short_left={d.into_iter().eq_by(a.into_iter(), (p, q) => p == q)}")

    comparators()
    return 0

# The comparator-taking terminals, which need a real `ordering`.
def cmp_int(a: int32, b: int32) -> ordering:
    if a < b:
        return @less
    if a > b:
        return @greater
    return @equal

# Reversed, so `min_by` under it must agree with `max` and disagree with `min`
# over the same source -- the same trick the `_by_key` checks use.
def rcmp_int(a: int32, b: int32) -> ordering:
    return cmp_int(b, a)

# The comparators are passed as lambdas rather than by name: a bare function
# value outside call position does not lower yet (`spec/todo.md`).
def show_ord(o: ordering) -> int32:
    return match o:
        @less => 1
        @equal => 2
        @greater => 3

def comparators() -> unit:
    let xs = [3, 1, 4, 1, 5]
    let empty: list[int32] = []

    println("min_by={xs.into_iter().min_by((a, b) => cmp_int(a, b)).unwrap()}")
    println("max_by={xs.into_iter().max_by((a, b) => cmp_int(a, b)).unwrap()}")
    println("min_by_rev={xs.into_iter().min_by((a, b) => rcmp_int(a, b)).unwrap()}")
    println("max_by_rev={xs.into_iter().max_by((a, b) => rcmp_int(a, b)).unwrap()}")
    println("min_by_empty={empty.into_iter().min_by((a, b) => cmp_int(a, b)).is_none()}")

    # Lexicographic: equal, then a difference decided at the second element
    # rather than the first, then each length case. The differing pair is not
    # in first position so a `cmp_by` that only ever looked at one pair would
    # answer `@equal` for it.
    let a = [1, 2, 3]
    let b = [1, 2, 3]
    let c = [1, 9, 0]
    let d = [1, 2]
    println("cmp_same={show_ord(a.into_iter().cmp_by(b.into_iter(), (a, b) => cmp_int(a, b)))}")
    println("cmp_lt={show_ord(a.into_iter().cmp_by(c.into_iter(), (a, b) => cmp_int(a, b)))}")
    println("cmp_gt={show_ord(c.into_iter().cmp_by(a.into_iter(), (a, b) => cmp_int(a, b)))}")

    # A prefix is less than the whole, and the decision comes from running out
    # rather than from any comparison.
    println("cmp_prefix={show_ord(d.into_iter().cmp_by(a.into_iter(), (a, b) => cmp_int(a, b)))}")
    println("cmp_longer={show_ord(a.into_iter().cmp_by(d.into_iter(), (a, b) => cmp_int(a, b)))}")
