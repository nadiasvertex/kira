module deps.contract_ok

type positive = int32 where self > 0

def needs_positive(p: positive) -> int32:
    p

def reserve(n: usize) -> unit
pre n > 0, "cannot reserve zero bytes"
pre n < 4096, "requested size exceeds maximum"
: ()

# Both preconditions hold here, so this call is safe — but `reserve`'s own
# entry checks stay, because they answer for every caller, including
# `unproven` below.
def proved() -> unit:
    reserve(64)

# Nothing is known about `n`, so the checks stay and run. Not an error — this
# is what a contract is for.
def unproven(n: usize) -> unit:
    reserve(n)

# A `pre` a parameter's own type already guarantees is the one that does
# compile away (`checked_types::elided_contracts`): no call, from anywhere,
# could pass a `positive` that isn't positive.
def redundant_precondition(p: positive) -> int32
pre p > 0
: p

# A precondition is a *fact* inside the callee, which is what lets it satisfy
# a refinement with no further proof.
def precondition_is_a_fact(x: int32) -> int32
pre x > 0
: needs_positive(x)

# So is a struct invariant, for every value of the type.
type positive_int = { value: int32 }
    invariant self.value > 0

def invariant_is_a_fact(p: positive_int) -> int32:
    needs_positive(p.value)
