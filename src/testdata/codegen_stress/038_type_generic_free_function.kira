module codegen_stress.type_generic_free_function

# A free function generic over *types* (`def identity[T]`) is monomorphized once
# per concrete type its call sites solve for — `identity$int32`, `identity$bool`
# — by `semantic::checker::instantiate_type_generic`. The template itself is
# never lowered (`hir::lower_module` skips it, just as it skips a const-generic
# template); each instance is an ordinary function to both backends, so a call
# to `identity(7)` and a call to `identity(false)` compile to two distinct
# concrete functions. `choose[T]` proves a generic body with control flow and
# more than one type parameter position solving to the same `T`.

def identity[T](x: T) -> T:
    return x

def choose[T](flag: bool, a: T, b: T) -> T:
    if flag:
        return a
    return b

# One generic function calling another: `wrap`'s body calls `identity`, but not
# until `wrap` is itself instantiated (its `T` bound to a concrete type) does
# that inner call have a concrete type to monomorphize against. While the
# `wrap` *template* is being checked, `in_type_generic_template_` keeps the
# inner `identity(x)` from being instantiated at the still-abstract `T`.
def wrap[T](x: T) -> T:
    return identity(x)

def main() -> int32:
    let a = identity(7)
    let b = choose(true, 30, 99)
    let c = choose(false, 1, 3)
    let d = wrap(2)
    let done = identity(false)
    if done:
        return 0
    return a + b + c - d
