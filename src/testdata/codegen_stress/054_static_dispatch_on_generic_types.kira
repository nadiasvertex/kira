module codegen_stress.static_dispatch_on_generic_types

# `static def` reached through a generic type: the three distinct defects that
# stood between §5.1's `collect` and a working program.
#
# 1. An impl for an *applied builtin generic* — `impl from_iter[int32] for
#    list[int32]` — was never registered at all. `build_method_table` keyed
#    impl members either by the target's `type_decl` or, for a bare prelude
#    constructor, by its name; an applied builtin has neither a `type_decl`
#    nor `ctor_ref_kind`, so it fell through a `continue` and vanished. The
#    impl parsed and was coherence-checked, then no lookup could see it:
#    `list[int32].from_iter(...)` reported no such static member however it
#    was spelled. Every collector in §5.1 is exactly this shape.
#
# 2. A `static def` carried by a *generic impl block* — `impl[T] maker[T] for
#    crate[T]` — got no compiled instance. Such a method declares no type
#    parameters of its own (the `T` belongs to the impl), so it took the
#    non-generic path, which names the callee `crate[int32]::make` and stops.
#    Nothing had instantiated the impl for `int32`, so no function ever bore
#    that name: the call type-checked and then died in lowering with "could
#    not be resolved to a function in this compiled module". Type-checking a
#    call while compiling nothing for it is the split
#    `check_impl_generic_method_call` already prevented for receiver-taking
#    methods; the static path now shares its instance discipline.
#
# 3. `Type[Args].method()` did not resolve as a receiver at all.
#    `infer_qualified_call` accepted only a plain name or a module path, and
#    a generic application is neither: `gen[int32]` reaches the checker as an
#    *index* expression and `map[str, int32]` as a *call*, because in
#    expression position that is all the parser could know. Whether the head
#    names a value is what settles it, and that is a name-resolution
#    question, so it is decided in the checker.
#
# `# expect:` rather than cross-tier agreement, per CLAUDE.md: both backends
# resolve these calls from the same checker output, so a static call that
# dispatched to the *wrong* instance — the sibling collector, or an instance
# built for the wrong type argument — would dispatch identically wrongly in
# both and agree perfectly. Only a computed value catches that, so every
# collector below produces a different arithmetic signature.

# sum:   0+1+2+3+4         = 10, len 5   -> 10 * 10 + 5    =  105
# count: 5 elements                      -> 5 * 1000       = 5000
# doubled sum: 0+2+4+6+8   = 20          -> 20 * 100       = 2000
# crate[int32].make(9).v   = 9           -> 9              =     9
# 105 + 5000 + 2000 + 9 = 7114
# expect: 7114

trait iterator[T]:
    def next(mut self) -> option[T]

type upto = { at: int32, end: int32 }

impl iterator[int32] for upto:
    def next(mut self) -> option[int32]:
        if self.at >= self.end:
            return @none
        let v = self.at
        self.at = self.at + 1
        return @some(v)

trait from_iter[T]:
    static def from_iter[I](it: I) -> self

# Defect 1: the collector on a builtin generic. Sums as it collects, so a
# `collect` that dispatched here when it meant `counter` would show up in the
# arithmetic rather than merely in the type.
impl from_iter[int32] for list[int32]:
    static def from_iter[I](it: I) -> list[int32] where I: iterator[int32]:
        var out = []
        var cursor = it
        while let @some(x) = cursor.next():
            out.push(x)
        return out

type counter = { seen: int32 }

# A second collector, so the choice between them is a real choice. If static
# dispatch on the solved type were ignored and one collector always won, one
# of the three terms below would be wrong.
impl from_iter[int32] for counter:
    static def from_iter[I](it: I) -> counter where I: iterator[int32]:
        var cursor = it
        var n = 0
        while let @some(x) = cursor.next():
            n = n + 1
        return counter { seen: n }

type doubler = { total: int32 }

impl from_iter[int32] for doubler:
    static def from_iter[I](it: I) -> doubler where I: iterator[int32]:
        var cursor = it
        var acc = 0
        while let @some(x) = cursor.next():
            acc = acc + x * 2
        return doubler { total: acc }

# §5.1's `collect`, verbatim: one function, the collector chosen entirely by
# the type expected at the call site (R1 return-position inference).
def collect[I, C](it: I) -> C:
    return C.from_iter(it)

type crate[T] = { v: T }

trait maker[T]:
    static def make(v: T) -> self

# Defect 2: a static method whose only generic content is its impl block's.
impl[T] maker[T] for crate[T]:
    static def make(v: T) -> crate[T]:
        return crate { v: v }

def main() -> int32:
    # Three collectors, three result types, one `collect`. Each is chosen by
    # its annotation alone — nothing at the call site differs but the type.
    let xs: list[int32] = collect(upto { at: 0, end: 5 })
    var total = 0
    var seen = 0
    for x in xs:
        total = total + x
        seen = seen + 1

    let counted: counter = collect(upto { at: 0, end: 5 })
    let doubled: doubler = collect(upto { at: 0, end: 5 })

    # Defect 3: the qualified-path receiver form, reaching the same instance
    # the type-parameter form above reaches.
    let made = crate[int32].make(9)

    return total * 10 + seen + counted.seen * 1000 + doubled.total * 100 + made.v
