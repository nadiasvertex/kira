module sample
type header = { pub magic: uint16, pub flags: byte, pub len: uint32 }
def combine(magic: uint16, flags: byte, len: uint32) -> int64:
    let h: header = { magic: magic, flags: flags, len: len }
    return (h.magic as int64) * 1000000 + (h.flags as int64) * 1000 + (h.len as int64)
def make(magic: uint16, flags: byte, len: uint32) -> header:
    return { magic: magic, flags: flags, len: len }
def make_fixed() -> header:
    return { magic: 0x1234, flags: 0xAB, len: 0xDEADBEEF }
def main() -> int64:
    return combine(7, 3, 42)
